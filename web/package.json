{
  "name": "kickabout-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.ts",
    "dev:server": "tsx watch server/src/index.ts",
    "server": "tsx server/src/index.ts",
    "start": "npm run server",
    "build": "tsc -p tsconfig.json && vite build --config client/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "concurrently": "^8.2.2",
    "phaser": "^3.90.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "ws": "^8.18.0"
  }
}
